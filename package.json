{
  "name": "playwright-test",
  "version": "1.0.0",
  "description": "Playwright parallel test with grouped execution",
  "scripts": {
    "test": "playwright test",
    "test:headed": "node scripts/run-tests-grouped.js main --project=chromium",
    "test:headed:paytransfer": "node scripts/run-tests-grouped.js paytransfer",
    "test:main:chrome": "node scripts/run-tests-chrome.js main",
    "test:headed:files": "node scripts/run-tests.js files",
    "test:headed:login": "node scripts/run-tests.js login",
    "test:multi-window": "node scripts/run-multi-window.js",
    "test:login": "playwright test --headed tests/login.spec.ts --project=chromium --project=firefox",
    "test:act": "playwright test --headed src/e2e/IDEALX/PayTransfer/SG_ACT_NewPayee.test.ts --project=chromium --project=firefox",
    "test:act:chrome": "playwright test --headed src/e2e/IDEALX/PayTransfer/SG_ACT_NewPayee.test.ts --project=chromium",
    "test:act:firefox": "playwright test --headed src/e2e/IDEALX/PayTransfer/SG_ACT_NewPayee.test.ts --project=firefox",
    "test:chrome": "playwright test --headed --project=chromium",
    "test:firefox": "playwright test --headed --project=firefox",
    "test:single": "node scripts/run-tests.js",
    "install:browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^25.3.5",
    "@types/ssh2-sftp-client": "^9.0.6"
  },
  "dependencies": {
    "ssh2-sftp-client": "^12.1.0"
  }
}
